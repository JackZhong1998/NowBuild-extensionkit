# Extension (Vite) — copy to `.env` in the repo root
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_SYNC_HOST=https://your-sync-host.example

# Your deployed API (or http://localhost:8787 for local dev)
VITE_API_BASE_URL=http://localhost:8787

# Stripe success/cancel landing page (must be HTTPS in production)
# Can be a simple "Payment complete" page on your marketing site.
VITE_PUBLIC_APP_URL=https://your-site.example/stripe-done

# Optional: use a Stripe Payment Link instead of server-created Checkout Sessions
# VITE_STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/...

# Optional: Price id for the demo "Pay" button (server creates Checkout Session)
# VITE_STRIPE_PRICE_ID=price_...
